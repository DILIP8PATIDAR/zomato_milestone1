# ── Python ────────────────────────────────────────────────────────────────────

# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.env
.env.*

# ── Secrets / config ──────────────────────────────────────────────────────────

# API keys — never commit
*.env
.env.local
.env.*.local
config/secrets.py
secrets.json

# ── Testing ───────────────────────────────────────────────────────────────────

.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.hypothesis/

# ── Data / cache ──────────────────────────────────────────────────────────────

# Hugging Face dataset cache (re-downloadable)
~/.cache/huggingface/
.cache/
*.parquet
*.arrow
*.feather

# Large local dataset files
data/*.csv
data/*.json
data/*.jsonl
data/*.parquet

# ── IDE / OS ──────────────────────────────────────────────────────────────────

.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────

*.log
logs/

# ── Jupyter ───────────────────────────────────────────────────────────────────

.ipynb_checkpoints/
*.ipynb

# ── Type stubs ────────────────────────────────────────────────────────────────

*.pyi

# ── Frontend (nested project) — already has its own .gitignore ───────────────
# zomato_frontend/node_modules and .next are covered by its own file
